# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key"

# APP_URL: URL приложения (для бота и деплоя). Целевой хостинг: play2go.cloud
APP_URL="https://play2go.cloud/"

# VITE_API_URL: URL бэкенда (для Vercel). Обязательно при split-деплое!
# Пример: https://mgimo-api.up.railway.app
# VITE_API_URL="https://your-backend.up.railway.app"

# CORS_ORIGIN: для бэкенда. URL фронтенда (play2go.cloud или Vercel).
# CORS_ORIGIN="https://play2go.cloud"

# BOT_TOKEN: Токен Telegram-бота (только для scripts/setup-telegram-bot.mjs).
# BOT_TOKEN="your_bot_token"

# API_URL: URL бэкенда для бота (для /word, /words). Если бот и backend на одном хосте — можно не задавать.
# API_URL="https://your-backend.up.railway.app"
