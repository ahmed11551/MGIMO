# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key"

# APP_URL: URL приложения (для setup-telegram-bot.mjs и деплоя).
APP_URL="https://mgimo-ochre.vercel.app/"

# VITE_API_URL: URL бэкенда (для Vercel). Обязательно при split-деплое!
# Пример: https://mgimo-api.up.railway.app
# VITE_API_URL="https://your-backend.up.railway.app"

# CORS_ORIGIN: для бэкенда (Railway). URL фронтенда, например https://mgimo-ochre.vercel.app
# CORS_ORIGIN="https://mgimo-ochre.vercel.app"

# BOT_TOKEN: Токен Telegram-бота (только для scripts/setup-telegram-bot.mjs).
# BOT_TOKEN="your_bot_token"

# API_URL: URL бэкенда для бота (для /word, /words). Если бот и backend на одном хосте — можно не задавать.
# API_URL="https://your-backend.up.railway.app"
